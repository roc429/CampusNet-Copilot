# Vite 开发代理目标（复制为 .env.local 后修改）
# 连本机（需本地启动 8000/8001/8002 及 MCP）：
VITE_AGENT_PROXY_TARGET=http://127.0.0.1:8002
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000
VITE_NMB_PROXY_TARGET=http://127.0.0.1:8001

# 2.4 GraphRAG 检索可单独指向 ECS（其余接口仍走本机）：
# VITE_RAG_PROXY_TARGET=http://47.86.196.101:8002

# 2.7 TimesFM 预测（/api/mcp/call、/api/ops/predict）可单独指向 ECS：
# VITE_MCP_PROXY_TARGET=http://47.86.196.101:8002
# VITE_OPS_PROXY_TARGET=http://47.86.196.101:8002

# 监控 KPI（/api/monitor/telemetry-kpi）可单独指向 ECS：
# VITE_MONITOR_PROXY_TARGET=http://47.86.196.101:8000

# 报告中心（GET /admin/events）可单独指向 ECS Agent：
# VITE_ADMIN_PROXY_TARGET=http://47.86.196.101:8002

# 连远程 ECS（全部走后端在服务器上）：
# VITE_REMOTE_HOST=http://47.86.196.101
# VITE_AGENT_PROXY_TARGET=http://47.86.196.101:8002
# VITE_BACKEND_PROXY_TARGET=http://47.86.196.101:8000
# VITE_NMB_PROXY_TARGET=http://47.86.196.101:8001
# VITE_RAG_PROXY_TARGET=http://47.86.196.101:8002
