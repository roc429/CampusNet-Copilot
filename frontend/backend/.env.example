MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=campusnet-copilot

# 生产环境务必修改为随机长字符串
SECRET_KEY=dev-secret-change-in-production

# 阿里云百炼 API Key（控制台复制，勿提交到 Git）
DASHSCOPE_API_KEY=
# 可选：国际区或其它兼容端点
# DASHSCOPE_CHAT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 监控大屏遥测 CSV（默认：仓库根目录 telemetry.csv）
# TELEMETRY_CSV_PATH=E:/2026/XiaoXueQI/0526/CampusNet-Copilot/telemetry.csv

# Neo4j 知识图谱（与 NMB/docker-compose-neo4j.yml 默认一致）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
