DISABLE_ENV_PROXY=true
LLM_STRICT=false

# ===== MCP Server 端点 =====
# 旧版字段(保留兼容)
MCP_BASE_URL=http://localhost:9000

# NetBox MCP (官方 server,端口 7001)
NETBOX_MCP_SSE_URL=http://localhost:7001/sse

# 拆分后的独立 MCP Server (留空可禁用)
