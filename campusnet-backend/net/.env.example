GRAFANA_MCP_SSE_URL=http://localhost:9002/sse
TIMESFM_MCP_SSE_URL=http://localhost:9003/sse
CAMPUS_MCP_SSE_URL=http://localhost:9000/sse

MCP_SSE_READ_TIMEOUT=300

# ===== Prometheus MCP =====
