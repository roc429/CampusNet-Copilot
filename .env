# ==========================================
# 智网学伴 (CampusNet-Copilot) 环境变量配置
# ==========================================

# 1. Milvus 向量数据库配置
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=test_knowledge

# 2. Neo4j 图数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# 【注意】这里填你真实的 Neo4j 密码
NEO4J_PWD=password

# 3. BGE-M3 模型打分配置 (阈值越高，过滤越严格)
RERANK_THRESHOLD=-2.0