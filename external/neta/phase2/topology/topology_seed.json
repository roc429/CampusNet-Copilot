{
  "project": "campus_timesfm_demo_simple",
  "prometheus": {
    "pushgateway_url": "http://127.0.0.1:9091",
    "job": "campusnet"
  },
  "traffic": {
    "interval_seconds": 5,
    "normal_load_range": [0.25, 0.45],
    "warning_load_range": [0.65, 0.78],
    "anomaly_load_range": [0.92, 1.0]
  },
  "topology": {
    "core": {
      "name": "core"
    },
    "areas": [
      {
        "area_id": "302",
        "zone_id": "ZONE-TEACH",
        "area_name": "302教学区",
        "uplink": {
          "bw": 100,
          "delay": "2ms"
        },
        "aps": [
          {
            "device_id": "AP-EXAM-302",
            "device_name": "302考场AP",
            "dpid": "6",
            "port": "1",
            "role": "ap",
            "clients": 2,
            "link": {
              "bw": 50,
              "delay": "3ms"
            }
          }
        ]
      }
    ]
  }
}
