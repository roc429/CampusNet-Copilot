├── flow.py          # Ryu 控制器代码
└── campus.py        # Mininet 拓扑代码


# 核心-汇聚链路（高带宽）
self.addLink(core, agg_teaching, bw=1000, delay='5ms', loss=0)

core	        第一个交换机	    链路的一端（核心交换机）
agg_teaching	第二个交换机	    链路的另一端（汇聚交换机）
bw=1000	        1000 Mbps	      带宽 = 1Gbps
delay='5ms'	    5 毫秒	           单向传输延迟
loss=0	        0%	              丢包率

核心层 s1
汇聚层 s1->s2 s3 s4
接入层 s2->s5 s6 s7 s8
      s3->s9 s10 s11 s12
      s4->s13 s14 s15 s16 


层级	 设备数量	 设备名称	 链路带宽	       延迟	 丢包率
核心层	   1台	      s1	      -	             - 	   -
汇聚层	   3台	    s2,s3,s4	  -	             -	   -
核心-汇聚  3条	   s1→s2/s3/s4 1000 Mbps        5ms	   0%
接入层	   12台	    s5-s16	      -	             -	   -
汇聚-接入  12条	   各汇聚→接入	 100 Mbps	      2ms	 1%
教学区主机	10台	h1-h10	    10 Mbps	         1ms	0%
宿舍区主机	10台	h11-h20	    10 Mbps	         1ms	0%
服务器	    3台	  web,dns,gw   100-1000 Mbps	1ms	   0%

